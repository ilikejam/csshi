import argparse
import asyncio
import logging
import os
import re
import shutil
import sys
from dataclasses import dataclass, field
from functools import partial
from math import ceil, floor, sqrt
from time import monotonic, sleep
from typing import NoReturn

import iterm2
from AppKit import NSRunningApplication  # type: ignore
from AppKit import NSWorkspace  # type: ignore
from AppKit import NSWorkspaceOpenConfiguration  # type: ignore
from iterm2 import LocalWriteOnlyProfile as LocalProfile
from iterm2 import Profile, Window
from iterm2.app import App
from iterm2.connection import Connection
from iterm2.profile import TitleComponents
from iterm2.session import Session
from iterm2.tab import Tab

logger: logging.Logger = logging.getLogger(__name__)
bundle_id = "com.googlecode.iterm2"
# We prepend U+2064 INVISIBLE PLUS to session names so we know they're from csshi
session_name_prefix = "\u2064"


@dataclass
class Destination:
    host: str
    user: str | None = None
    port: str | None = None


@dataclass
class Config:
    binary: str = ""
    broadcast: bool = True
    caffeine: bool = False
    cols: int = 0
    debug: bool = False
    destinations: list[Destination] = field(default_factory=list)
    jumphost: str | None = None
    kill_defunct: bool = False
    options: list[str] = field(default_factory=list)
    profile: str | None = None
    rows: int = 0
    shell: str = ""
    sleep: float = 0
    ssh_exec_string: str = ""


def error(message: str) -> NoReturn:
    """Scream and die"""
    logger.error(message)
    sys.exit(1)


def setup_logging(debug: bool) -> None:
    """Set log level and format for debug/normal"""
    if debug:
        logging.basicConfig(level=logging.DEBUG)
    else:
        logging.basicConfig(level=logging.INFO, format="%(levelname)s: %(message)s")


def iterm_running() -> bool:
    """Check if iTerm2 is running"""
    return bool(
        NSRunningApplication.runningApplicationsWithBundleIdentifier_(bundle_id)
    )


def get_arg_parser() -> argparse.ArgumentParser:
    """Parse user args, as is tradition"""
    parser = argparse.ArgumentParser(
        description="Run multiple ssh connections concurrently in an iTerm2 terminal."
    )
    parser.add_argument(
        "-d", "--debug", dest="debug", action="store_true", help="Turn on debugging"
    )
    parser.add_argument(
        "-k",
        "--kill-inactive",
        dest="kill",
        action="store_true",
        help="Don't create spacer panes and kill inactive panes",
    )
    parser.add_argument(
        "-c",
        "--caffeinate",
        dest="caffeine",
        action="store_true",
        help="Try to keep the Mac awake",
    )
    parser.add_argument(
        "-n",
        "--no-broadcast",
        dest="nobroadcast",
        action="store_true",
        help="Don't enable input broadcast",
    )
    parser.add_argument(
        "-l",
        "--username",
        dest="username",
        help="Login username, overridden per-host by specifying 'user@host'",
    )
    parser.add_argument(
        "-p",
        "--port",
        dest="port",
        type=str,
        help="ssh server port, overridden per-host by specifying 'host:port'",
    )
    parser.add_argument(
        "-J",
        "--jump",
        dest="jumphost",
        help="ProxyJump host specification, like [user@]jumphost[:port]",
    )
    parser.add_argument(
        "-s",
        "--sleep",
        dest="sleep",
        default=0,
        type=float,
        help="Sleep time in seconds between hosts. Defaults to 0",
    )
    parser.add_argument(
        "-o",
        "--options",
        action="append",
        dest="options",
        help="Raw ssh options string, e.g. '-i ~/.ssh/id_ansible'. Can be specified multiple times.",
    )
    parser.add_argument(
        "-b",
        "--binary",
        dest="binary",
        default="ssh",
        help="SSH binary to use. Defaults to 'ssh'",
    )
    parser.add_argument(
        "-P",
        "--profile",
        dest="profile",
        help="iTerm2 settings Profile to use for csshi window. Defaults to your default Profile.",
    )
    grid_group = parser.add_mutually_exclusive_group()
    grid_group.add_argument(
        "-C",
        "--columns",
        dest="columns",
        type=int,
        help="Maximum number of columns to use.",
    )
    grid_group.add_argument(
        "-R", "--rows", dest="rows", type=int, help="Maximum number of rows to use."
    )
    runtype_group = parser.add_mutually_exclusive_group(required=True)
    runtype_group.add_argument(
        "destinations",
        metavar="destination",
        nargs="*",
        help="[user@]host[:port] ssh connection specification. NB: Square brackets MUST be used around IPv6 IP adresses",
    )
    runtype_group.add_argument(
        "-L",
        "--list-sessions",
        dest="list_sessions",
        action="store_true",
        help="Print space-separated list of csshi sessions, one line per window",
    )
    return parser


def get_destination_host(destination: str) -> str:
    """Parse out a host from a user-specified destination spec"""
    host: str = ""
    if re.search(r"\[..*\]", destination):
        host = destination.split("[")[1].split("]")[0]
    elif "@" in destination:
        host = destination.split("@")[1].split(":")[0]
    elif ":" in destination:
        host = destination.split(":")[0]
    else:
        host = destination
    if not host:
        error(f"ssh destination '{destination}' does not appear to include a host.")
    logger.debug(f"Found host {host} in destination {destination}")
    return host


def get_destination_user(destination: str, arg_user: str | None) -> str | None:
    """Parse out a username from a user-specified destination spec"""
    user: str | None = None
    if arg_user:
        user = arg_user
    if "@" in destination:
        user = destination.split("@")[0]
        logger.debug(f"Found user {user} in destination {destination}")
    return user


def get_destination_port(destination: str, arg_port: str | None) -> str | None:
    """Parse out a port from a user-specified destination spec"""
    port: str | None = arg_port
    if re.search(r"\[..*\]", destination):
        port = destination.split("]")[1].lstrip(":")
    elif ":" in destination:
        port = destination.split(":")[1]
    if port:
        logger.debug(f"Found port {port} in destination {destination}")
    return port


def build_ssh_string(config: Config, index: int) -> str:
    """Build an ssh command string from config and destination index"""
    ssh_args: list[str] = []
    if config.caffeine:
        ssh_args.extend(["caffeinate", "-dimsu"])
    ssh_args.append(config.binary)
    if config.destinations[index].user:
        ssh_args.extend(["-l", str(config.destinations[index].user)])
    if config.destinations[index].port:
        ssh_args.extend(["-p", str(config.destinations[index].port)])
    if config.jumphost:
        ssh_args.extend(["-J", config.jumphost])
    if config.options:
        for option in config.options:
            ssh_args.append(option)
    ssh_args.append(config.destinations[index].host)
    ssh_string: str = " ".join(ssh_args)
    return ssh_string


def get_user_shell() -> str:
    """Find the user's shell, or whichever bash is first in PATH"""
    shell: str | None = os.environ.get("SHELL")
    if shell:
        logger.debug(f"Using shell {shell} from $SHELL")
        return shell
    logger.debug("No $SHELL found, looking for bash")
    shell = shutil.which("bash")
    if shell:
        logger.debug(f"Using bash shell {shell}")
        return shell
    error("Could not find a local shell to run. Set $SHELL or install bash.")


def set_columns(columns: int | None, rows: int | None, sessions: int) -> int:
    """Set a calculated number of columns, or user specified, whichever is less"""
    floor_square: int = floor(sqrt(sessions))
    if columns is not None and columns < 1:
        error("Columns cannot be < 1")
    if rows is not None and rows < 1:
        error("Rows cannot be < 1")
    if columns:
        if columns <= floor_square:
            logger.debug(f"Using columns argument: {columns}")
            return columns
        logger.debug("Not using columns argument - sqrt is lower")
    if rows:
        calc_columns = ceil(sessions / rows)
        logger.debug(
            f"Using {calc_columns} columns from {sessions} destinations, {rows} rows"
        )
        return calc_columns
    return floor_square


def build_config(args: argparse.Namespace) -> Config:
    """Build a config object from the user args"""
    config = Config()
    num_destinations: int = len(args.destinations)
    config.binary = args.binary
    config.broadcast = not args.nobroadcast
    config.caffeine = args.caffeine
    config.cols = set_columns(args.columns, args.rows, num_destinations)
    config.debug = args.debug
    config.jumphost = args.jumphost
    config.kill_defunct = args.kill
    config.options = args.options
    config.profile = args.profile
    config.rows = ceil(num_destinations / config.cols)
    config.shell = get_user_shell()
    config.sleep = args.sleep
    config.ssh_exec_string = f"{config.shell} -c '{{ssh_string}}'"
    for destination in args.destinations:
        config.destinations.append(
            Destination(
                host=get_destination_host(destination),
                user=get_destination_user(destination, args.username),
                port=get_destination_port(destination, args.port),
            )
        )
    return config


def gen_ssh_profile() -> LocalProfile:
    """iTerm base profile for ssh panes"""
    profile = iterm2.LocalWriteOnlyProfile()
    profile.set_title_components([TitleComponents.SESSION_NAME])
    profile.set_allow_title_setting(False)
    profile.set_use_custom_command("Yes")
    profile.set_close_sessions_on_end(False)
    return profile


def gen_spacer_profile(shell: str) -> LocalProfile:
    """iTerm profile for spacer panes - Just spit out a message a wait"""
    profile = iterm2.LocalWriteOnlyProfile()
    profile.set_use_custom_command("Yes")
    profile.set_command(f'{shell} -c "/bin/echo PANE NOT IN USE"')
    profile.set_close_sessions_on_end(False)
    return profile


def configure_ssh_profile(config: Config, profile: LocalProfile, index: int) -> None:
    """Set up a Profile for ssh"""
    ssh_string: str = build_ssh_string(config, index)
    logger.debug(f"{config.destinations[index].host} ssh_exec_string: {ssh_string}")
    profile.set_command(config.ssh_exec_string.format(ssh_string=ssh_string))
    profile.set_name(f"{session_name_prefix}{config.destinations[index].host}")


async def set_broadcast(app: App, connection: Connection, tab: Tab) -> None:
    """Attach user input to the ssh panes"""
    domain = iterm2.broadcast.BroadcastDomain()
    for session in tab.sessions:
        domain.add_session(session)
    bc_domains = app.broadcast_domains
    bc_domains.append(domain)
    logger.debug("Enabling input broadcast")
    await iterm2.async_set_broadcast_domains(connection, bc_domains)


async def check_profile(connection: Connection, profile_name: str) -> None:
    """Check that a specified iTerm2 profile exists"""
    for profile in await Profile.async_get(connection):
        logger.debug(f"Found iTerm2 profile {profile.name}")
        if profile.name == profile_name:
            logger.debug(f"Matched iTerm2 profile {profile.name}")
            return
    error(f"Could not find iTerm2 profile {profile_name}")


def launch_handler(_, launch_error) -> None:
    """Handle iTerm2 launch callback"""
    if launch_error:
        error("Could not launch iTerm2.")


def launch_iterm() -> None:
    """Launch iTerm2"""
    logger.debug("Launching iTerm...")
    workspace = NSWorkspace.sharedWorkspace()
    url = workspace.URLForApplicationWithBundleIdentifier_(bundle_id)
    if not url:
        error("Could not find iTerm2 application URL. Is iTerm2 installed?")
    nsconfig = NSWorkspaceOpenConfiguration.configuration()
    workspace.openApplicationAtURL_configuration_completionHandler_(
        url, nsconfig, launch_handler
    )
    deadline: float = monotonic() + 10
    while not iterm_running():
        if monotonic() > deadline:
            error("Timed out waiting for iTerm2 to launch.")
        logger.debug("Waiting for iTerm2 to launch...")
        sleep(1)
    logger.debug("iTerm2 running")


async def monitor_sessions(app: App, con: Connection, tab: Tab, reap: bool) -> None:
    """Wait for termination messages, and close any terminated sessions"""
    async with iterm2.SessionTerminationMonitor(con) as mon:
        while tab.sessions:
            try:
                session_id = await asyncio.wait_for(mon.async_get(), timeout=2)
            except asyncio.TimeoutError:
                if not iterm_running():
                    logger.debug("Iterm2 is not running - ending session monitor")
                    return
                if not tab.window:
                    logger.debug("Window gone - ending session monitor")
                    return
                continue
            logger.debug(f"Got termination for {session_id}")
            if reap:
                session: Session | None = app.get_session_by_id(session_id)
                if session:
                    if session in tab.sessions:
                        logger.debug(f"Closing session {session_id}")
                        await session.async_close()
                    else:
                        logger.debug(f"Ignoring session {session_id} - not in our tab")
                else:
                    logger.debug(f"Session for {session_id} gone")


async def sessions_run(config: Config, connection: Connection) -> None:
    """Launch all sessions and spacers"""
    ssh_profile: LocalProfile = gen_ssh_profile()
    spacer_profile: LocalProfile = gen_spacer_profile(config.shell)
    logger.debug("Connecting to iTerm")
    app: App = await iterm2.async_get_app(connection) or error(
        "Could not connect to iTerm2"
    )
    logger.debug("Connected")
    host_ind = 0
    # Launch the first pane straight into ssh
    logger.debug("Launching 1st pane")
    configure_ssh_profile(config, ssh_profile, host_ind)
    if config.profile:
        await check_profile(connection, config.profile)
    window: Window = await iterm2.Window.async_create(
        connection, profile=config.profile, profile_customizations=ssh_profile
    ) or error("Could not create new iTerm2 window")
    tab: Tab = window.current_tab or error("Could not get current tab for window")
    # Launch the rest of the first row into ssh
    # First row will always be all ssh panes, no spacers
    session: Session = tab.current_session or error("Could not get current session")
    column_heads: list[Session] = [session]
    for _ in range(config.cols - 1):
        logger.debug(f"Sleeping for {config.sleep} seconds")
        await asyncio.sleep(config.sleep)
        host_ind += 1
        logger.debug("Splitting pane")
        configure_ssh_profile(config, ssh_profile, host_ind)
        session = await session.async_split_pane(
            vertical=True, profile=config.profile, profile_customizations=ssh_profile
        ) or error("Could not split pane for ssh session")
        column_heads.append(session)
    # Create the rest of the pane rows, either as ssh or spacer
    total_sessions = config.cols
    column_tails = column_heads.copy()  # new pane rows are split from the bottom
    for _ in range(config.rows - 1):
        for j in range(config.cols):
            total_sessions += 1
            if total_sessions <= len(config.destinations):
                # Still launching ssh panes
                host_ind += 1
                logger.debug(f"Sleeping for {config.sleep} seconds")
                await asyncio.sleep(config.sleep)
                logger.debug("Splitting pane")
                configure_ssh_profile(config, ssh_profile, host_ind)
                last = await column_tails[j].async_split_pane(
                    vertical=False,
                    profile=config.profile,
                    profile_customizations=ssh_profile,
                )
            elif not config.kill_defunct:
                # If '-k' flag is _not_ specified, launch spacer panes to fill last row
                logger.debug("Splitting pane for spacer")
                last = await column_tails[j].async_split_pane(
                    vertical=False,
                    profile=config.profile,
                    profile_customizations=spacer_profile,
                )
            else:
                continue
            column_tails[j] = last
    if config.broadcast:
        await set_broadcast(app, connection, tab)
    logger.debug("Arranging panes")
    await iterm2.MainMenu.async_select_menu_item(
        connection, "Arrange Split Panes Evenly"
    )
    logger.debug("Activating 1st pane")
    await tab.sessions[0].async_activate()
    if config.kill_defunct or config.debug:
        logger.info("Waiting for sessions to terminate...")
        await monitor_sessions(app, connection, tab, config.kill_defunct)


async def sessions_list(connection: Connection) -> None:
    """Print out sessions started by csshi"""
    logger.debug("Connecting to iTerm")
    app: App = await iterm2.async_get_app(connection) or error(
        "Could not connect to iTerm2"
    )
    logger.debug("Connected")
    windows: dict[str, list[str]] = {}
    for window in app.windows:
        windows[window.window_id] = []
        for tab in window.tabs:
            for session in tab.sessions:
                if session.name.startswith(session_name_prefix):
                    windows[window.window_id].append(
                        session.name[len(session_name_prefix) :]
                    )
    for session_list in windows.values():
        if session_list:
            print(" ".join(session_list))


if __name__ == "__main__":
    args: argparse.Namespace = get_arg_parser().parse_args()
    setup_logging(args.debug)
    if args.list_sessions:
        iterm2.run_until_complete(sessions_list)
    else:
        config: Config = build_config(args)
        launch_iterm()
        iterm2.run_until_complete(partial(sessions_run, config))
